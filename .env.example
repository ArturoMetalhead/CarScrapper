# Copia este archivo a .env y ajusta los valores.

# --- Django ---
SECRET_KEY=cambia-esta-clave-por-una-secreta
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Base de datos (opcional). Por defecto usa SQLite.
# DATABASE_URL=postgres://usuario:password@localhost:5432/carscrapper

# --- CORS (frontend permitido) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Scraper ---
# URL base del sitio al que se le hará scraping.
SCRAPER_BASE_URL=
SCRAPER_TIMEOUT=20
# SCRAPER_USER_AGENT=Mozilla/5.0 ...

# Aplicar playwright-stealth en los providers con navegador.
SCRAPER_USE_STEALTH=True

# Proxy opcional (residencial o de un servicio de scraping) para evadir
# bloqueos por IP como el de Edmunds. Formato:
#   http://usuario:password@host:puerto
SCRAPER_PROXY=

# --- nodriver (anti-DataDome) ---
# Edmunds usa DataDome, que bloquea a Playwright/Selenium. El provider de
# Edmunds usa un Chrome real vía nodriver para atravesarlo. Requiere correr
# desde una IP no fichada (residencial) y con Chrome instalado.
# Carpeta de perfil DEDICADA al scraper (no tu perfil personal). Persiste la
# cookie datadome; por defecto <proyecto>/.chrome_profile_scraper.
# SCRAPER_NODRIVER_PROFILE_DIR=
# Ventana visible (True, verificado) vs headless (puede fallar; en servidor
# sin pantalla necesita xvfb).
SCRAPER_NODRIVER_HEADLESS=False
# Reintentos con recarga ante un 403 de DataDome.
SCRAPER_NODRIVER_RETRIES=3
# Segundos de espera tras navegar para que asiente el reto JS.
SCRAPER_NODRIVER_SETTLE=6
