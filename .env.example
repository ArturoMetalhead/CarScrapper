# Copy this file to .env and adjust the values.

# --- Django ---
SECRET_KEY=change-this-to-a-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (optional). Uses SQLite by default.
# DATABASE_URL=postgres://user:password@localhost:5432/carscrapper

# --- CORS (allowed frontend) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Scraper ---
# Base URL of the site to scrape.
SCRAPER_BASE_URL=
SCRAPER_TIMEOUT=20
# SCRAPER_USER_AGENT=Mozilla/5.0 ...

# Apply playwright-stealth in browser-based providers.
SCRAPER_USE_STEALTH=True

# Optional proxy (residential or a scraping service) to bypass IP blocks like
# Edmunds'. Format:
#   http://user:password@host:port
SCRAPER_PROXY=

# --- nodriver (anti-DataDome) ---
# Edmunds uses DataDome, which blocks Playwright/Selenium. The Edmunds provider
# uses a real Chrome via nodriver to get through. Requires running from a
# non-flagged (residential) IP and with Chrome installed.
# Profile folder DEDICATED to the scraper (not your personal profile). Persists
# the datadome cookie; defaults to <project>/.chrome_profile_scraper.
# SCRAPER_NODRIVER_PROFILE_DIR=
# Headless is detected/blocked by DataDome; keep this False.
SCRAPER_NODRIVER_HEADLESS=False
# Hide the window off-screen (no visible window) while still passing DataDome.
# This is how to run "in the background". Only applies when HEADLESS is False.
SCRAPER_NODRIVER_HIDE_WINDOW=True
# Retries with reload on a DataDome 403.
SCRAPER_NODRIVER_RETRIES=3
# Seconds to wait after navigating so the JS challenge settles.
SCRAPER_NODRIVER_SETTLE=6

# --- VIN lookup, cache and background queue ---
# Timeout for NHTSA VIN decoding (free, no API key).
SCRAPER_VIN_DECODE_TIMEOUT=15
# Hours the per-model market data is considered fresh (then re-scraped).
SCRAPER_CACHE_TTL_HOURS=24
# Background worker: starts with the API (thread). False = run it separately.
SCRAPER_WORKER_AUTOSTART=True
# Queue poll (s) and retries per job.
SCRAPER_WORKER_POLL_SECONDS=5
SCRAPER_JOB_MAX_ATTEMPTS=3

# --- Background crawler ---
# Proactively discover, scrape and refresh models (on top of on-demand lookups).
# Crawl jobs run at low priority so user lookups always jump ahead.
SCRAPER_CRAWL_ENABLED=True
# Makes to crawl (comma-separated; empty = mainstream default list).
SCRAPER_CRAWL_MAKES=
# How many recent model years to cover.
SCRAPER_CRAWL_YEARS_BACK=8
# Planner cycle (s), queue low-water mark, and batch size per cycle.
SCRAPER_CRAWL_PLAN_INTERVAL=900
SCRAPER_CRAWL_QUEUE_MIN=20
SCRAPER_CRAWL_BATCH=50
# How long the discovered model list is cached before re-discovering.
SCRAPER_CRAWL_DISCOVERY_TTL_HOURS=24

# --- Frontend notification webhook ---
# URL the backend POSTs to when a scrape finishes (data ready).
# Can be overridden per request with the "webhook_url" field.
SCRAPER_WEBHOOK_URL=
SCRAPER_WEBHOOK_TIMEOUT=10
