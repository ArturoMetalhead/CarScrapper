# Copia este archivo a .env y ajusta los valores.

# --- Django ---
SECRET_KEY=cambia-esta-clave-por-una-secreta
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Base de datos (opcional). Por defecto usa SQLite.
# DATABASE_URL=postgres://usuario:password@localhost:5432/carscrapper

# --- CORS (frontend permitido) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Scraper ---
# URL base del sitio al que se le hará scraping.
SCRAPER_BASE_URL=
SCRAPER_TIMEOUT=20
# SCRAPER_USER_AGENT=Mozilla/5.0 ...

# Aplicar playwright-stealth en los providers con navegador.
SCRAPER_USE_STEALTH=True

# Proxy opcional (residencial o de un servicio de scraping) para evadir
# bloqueos por IP como el de Edmunds. Formato:
#   http://usuario:password@host:puerto
SCRAPER_PROXY=
